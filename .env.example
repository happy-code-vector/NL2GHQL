# LLM Provider Configuration
# Copy this file to .env and fill in your values

# Provider: gemini (recommended), openai, vllm, or mock
LLM_PROVIDER=gemini

# Gemini Configuration (recommended for NL2GraphQL)
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI Configuration (alternative)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1

# vLLM Configuration (Local Model)
# VLLM_API_KEY=dummy
# VLLM_MODEL=models/hermes_miner
# VLLM_BASE_URL=http://localhost:8000/v1

# LLM Parameters
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# GraphQL Endpoint Configuration
GRAPHQL_ENDPOINT=https://index-api.onfinality.io/sq/subquery/subquery-mainnet
GRAPHQL_API_KEY=your-graphql-api-key
GRAPHQL_AUTH_TYPE=bearer

# Agent Configuration
AGENT_MAX_RETRIES=3
AGENT_RECURSION_LIMIT=12
ENABLE_CACHE=true

# Weaviate Configuration (optional, for RAG)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_COLLECTION=graphql_schema

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Debug Mode
DEBUG=false
